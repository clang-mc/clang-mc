// ConstantFoldingPass 扩充 fixture（-O1 -E）。见 run_ir_opt_tests.py 的 cfold_extra 检查。
//   sub r0,0 -> 代数化简为 nop（删除）。
//   mul r1,1 -> 代数化简为 nop（删除）。
//   div r2,2 -> 不折叠（MC 为向下取整除法，语义不同），保留 `div r2, 2`。
//   add r3,1 于 INT_MAX 上 -> 32 位环绕，折叠为 mov r3, -2147483648。
_start:
    mov r0, 50
    sub r0, 0
    mov r1, 60
    mul r1, 1
    mov r2, 8
    div r2, 2
    mov r3, 2147483647
    add r3, 1
    ret
